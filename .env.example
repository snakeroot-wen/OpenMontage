# OpenMontage - Environment Variables
# Copy this to .env and fill in your keys. Never commit real secrets.

# --- OpenAI-compatible image / TTS ---
# OPENAI_BASE_URL is optional. Use it only for an OpenAI-compatible relay.
OPENAI_API_KEY=              # OpenAI or compatible relay key
OPENAI_BASE_URL=             # Optional, e.g. https://api.openai.com/v1 or relay /v1
OPENAI_IMAGE_MODEL=gpt-image-2

# LiteLLM-compatible image relay, optional/future-facing.
LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_IMAGE_MODEL=gpt-image-2

# --- fal.ai image + video gateway ---
# One key can enable FLUX/Recraft images and Veo/Kling/MiniMax/Seedance video.
FAL_KEY=                     # Get one at https://fal.ai/dashboard/keys
FAL_API_KEY=
FAL_AI_API_KEY=

# --- Google image + TTS ---
GOOGLE_API_KEY=              # Google Gemini/Imagen images, Google Cloud TTS
GEMINI_API_KEY=              # Alternative name used by some Google tooling
GOOGLE_APPLICATION_CREDENTIALS=   # path to a service-account JSON key file
GOOGLE_CLOUD_PROJECT=             # GCP project id for Vertex AI paths
GOOGLE_CLOUD_LOCATION=us-central1

# --- xAI Grok image/video ---
XAI_API_KEY=                 # Grok image generation/editing and Grok video

# --- Direct video generation ---
HEYGEN_API_KEY=              # HeyGen API gateway / avatar / video
RUNWAY_API_KEY=              # Runway Gen-4 / Seedance where account supports it
REPLICATE_API_TOKEN=         # Replicate-hosted Seedance etc.
HIGGSFIELD_API_KEY=          # Higgsfield Cloud API key
HIGGSFIELD_API_SECRET=       # Higgsfield Cloud API secret
HIGGSFIELD_KEY=              # Alternative combined key:secret form
MODAL_LTX2_ENDPOINT_URL=     # Modal self-hosted LTX-2 endpoint
VIDEO_GEN_LOCAL_ENABLED=     # true for local video gen; needs GPU + deps
VIDEO_GEN_LOCAL_MODEL=       # wan2.1-1.3b, wan2.1-14b, hunyuan-1.5, ltx2-local, cogvideo-5b

# --- Other image providers / aggregators ---
OPENROUTER_API_KEY=          # OpenRouter image models
DEEPINFRA_API_KEY=           # DeepInfra FLUX/Qwen/SDXL image models
MINIMAX_API_KEY=             # MiniMax direct/portal image path if supported
MINIMAX_OAUTH_TOKEN=         # MiniMax portal OAuth path if supported
COMFY_API_KEY=               # Comfy API key
COMFY_CLOUD_API_KEY=         # Comfy Cloud API key
VYDRA_API_KEY=               # Vydra Grok Imagine path if used

# --- Voice / music ---
ELEVENLABS_API_KEY=          # TTS narration, music generation, sound effects
SUNO_API_KEY=                # Suno AI music generation
FREESOUND_API_KEY=           # Freesound music/SFX search
DOUBAO_SPEECH_API_KEY=       # Volcengine Doubao Speech TTS
DOUBAO_SPEECH_VOICE_TYPE=    # e.g. zh_female_vv_uranus_bigtts
# Piper local voices do not require env vars; install `piper-tts` via pip.

# --- Stock Media ---
PEXELS_API_KEY=              # Pexels stock footage/images
PIXABAY_API_KEY=             # Pixabay stock footage/images/music
UNSPLASH_ACCESS_KEY=         # Unsplash stock images
COVERR_API_KEY=              # Coverr stock footage if used
VIDEVO_API_KEY=              # Videvo stock footage if used
NARA_API_KEY=                # NARA source if used
POND5_API_KEY=               # Pond5 public-domain source if used

# --- Analysis ---
HF_TOKEN=                    # HuggingFace token, e.g. diarization in transcriber

# --- Avatar local installs ---
WAV2LIP_PATH=                # Path to cloned Wav2Lip repo
SADTALKER_PATH=              # Path to cloned SadTalker repo
